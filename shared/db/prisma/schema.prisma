generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth ────────────────────────────────────────────────────────────────────

model User {
  id           String            @id @default(cuid())
  email        String            @unique
  /// Null when the user authenticates exclusively via an external identity provider (OIDC/SAML).
  passwordHash String?
  name         String?
  role         UserRole          @default(MEMBER)
  status       UserStatus        @default(ACTIVE)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  /// Soft-delete timestamp. `status = INACTIVE` is used for temporary suspension; deletedAt is irreversible.
  deletedAt    DateTime?
  sessions     Session[]
  identities   IdentityAccount[]
  messages     MsgMessage[]
  ownedProjects Project[]         @relation("ProjectOwner")
  assignedTasks Task[]            @relation("TaskAssignee")
}

enum UserRole {
  ADMIN
  MEMBER
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

model Session {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// SHA-256 of the session token. Raw tokens are never stored.
  tokenHash  String    @unique
  expiresAt  DateTime
  ipAddress  String?
  userAgent  String?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
}

/// External identity binding. One User may have zero or many IdentityAccounts —
/// one per (provider, providerId) combination. `LOCAL` provider is implied by
/// a non-null `passwordHash` on User; it does not require an IdentityAccount row.
model IdentityAccount {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider    IdentityProvider
  /// IdP instance name (e.g. `google`, `okta`, `azure-ad`, `authentik`).
  providerId  String
  /// Stable external subject (OIDC `sub` claim, SAML NameID).
  subject     String
  email       String?
  rawProfile  Json?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([provider, providerId, subject])
  @@index([userId])
}

enum IdentityProvider {
  LOCAL
  OIDC
  SAML
}

model Bot {
  id          String       @id @default(cuid())
  name        String
  description String?
  scopes      String[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  apiKeys     BotApiKey[]
  messages    MsgMessage[]
}

model BotApiKey {
  id        String    @id @default(cuid())
  botId     String
  bot       Bot       @relation(fields: [botId], references: [id], onDelete: Cascade)
  keyHash   String    @unique
  label     String?
  lastUsed  DateTime?
  createdAt DateTime  @default(now())
}

// ─── Messaging ───────────────────────────────────────────────────────────────

model MsgThread {
  id        String       @id @default(cuid())
  title     String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  messages  MsgMessage[]
}

model MsgMessage {
  id         String    @id @default(cuid())
  threadId   String
  thread     MsgThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  content    String
  senderType String // 'user' | 'bot' | 'agent'
  senderId   String
  userId     String?
  user       User?     @relation(fields: [userId], references: [id])
  botId      String?
  bot        Bot?      @relation(fields: [botId], references: [id])
  createdAt  DateTime  @default(now())
}

// ─── Agents ──────────────────────────────────────────────────────────────────

model AgentRun {
  id         String         @id @default(cuid())
  agentKey   String
  trigger    String
  status     AgentRunStatus @default(RUNNING)
  inputData  Json?
  outputData Json?
  error      String?
  startedAt  DateTime       @default(now())
  finishedAt DateTime?
  steps      AgentRunStep[]
}

enum AgentRunStatus {
  RUNNING
  COMPLETED
  FAILED
}

model AgentRunStep {
  id        String   @id @default(cuid())
  runId     String
  run       AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  type      String // 'llm' | 'tool'
  data      Json
  createdAt DateTime @default(now())
}

// ─── Workflows ───────────────────────────────────────────────────────────────

model WorkflowRun {
  id          String            @id @default(cuid())
  workflowKey String
  status      WorkflowRunStatus @default(PENDING)
  inputData   Json?
  error       String?
  startedAt   DateTime          @default(now())
  finishedAt  DateTime?
  steps       WorkflowRunStep[]
}

enum WorkflowRunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model WorkflowRunStep {
  id         String      @id @default(cuid())
  runId      String
  run        WorkflowRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  nodeId     String
  status     String
  inputData  Json?
  outputData Json?
  error      String?
  startedAt  DateTime    @default(now())
  finishedAt DateTime?
}

// ─── Notes ───────────────────────────────────────────────────────────────────

model Note {
  id        String   @id @default(cuid())
  title     String
  body      String   @default("")
  slug      String?  @unique
  tags      String[]
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Demo Objects ────────────────────────────────────────────────────────────

model Customer {
  id        String         @id @default(cuid())
  name      String
  email     String?        @unique
  phone     String?
  status    CustomerStatus @default(ACTIVE)
  notes     String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
}

model Product {
  id          String        @id @default(cuid())
  name        String
  description String?
  price       Float?
  status      ProductStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

enum ProductStatus {
  ACTIVE
  ARCHIVED
}

// ─── Projects & Tasks (example module) ───────────────────────────────────────

model Project {
  id            String        @id @default(cuid())
  name          String
  summary       String?
  status        ProjectStatus @default(PLANNED)
  priority      TaskPriority  @default(MEDIUM)
  ownerUserId   String?
  owner         User?         @relation("ProjectOwner", fields: [ownerUserId], references: [id])
  startDate     DateTime?
  targetDate    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  tasks         Task[]

  @@index([ownerUserId])
  @@index([status])
}

enum ProjectStatus {
  PLANNED
  ACTIVE
  BLOCKED
  DONE
  CANCELLED
}

model Task {
  id              String       @id @default(cuid())
  title           String
  description     String?
  status          TaskStatus   @default(TODO)
  priority        TaskPriority @default(MEDIUM)
  projectId       String
  project         Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assigneeUserId  String?
  assignee        User?        @relation("TaskAssignee", fields: [assigneeUserId], references: [id])
  dueAt           DateTime?
  blockedReason   String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([projectId])
  @@index([assigneeUserId])
  @@index([status])
  @@index([dueAt])
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ─── Action governance ───────────────────────────────────────────────────────

/**
 * Audit record for every action executed through the central dispatcher.
 * `status = PENDING_APPROVAL` rows are placeholders for the approval flow and
 * get promoted to RUNNING/COMPLETED once the request is approved and the
 * handler runs.
 */
model ActionExecution {
  id                  String                  @id @default(cuid())
  actionName          String
  actorType           String // 'user' | 'bot' | 'agent' | 'workflow'
  actorId             String
  status              ActionExecutionStatus   @default(RUNNING)
  risk                ActionRiskLevel         @default(LOW)
  input               Json?
  output              Json?
  error               String?
  approvalRequestId   String?                 @unique
  approvalRequest     ActionApprovalRequest?  @relation("ApprovalExecution", fields: [approvalRequestId], references: [id], onDelete: SetNull)
  correlationId       String?
  startedAt           DateTime                @default(now())
  completedAt         DateTime?
  durationMs          Int?

  @@index([actionName])
  @@index([actorType, actorId])
  @@index([status])
  @@index([startedAt])
}

enum ActionExecutionStatus {
  PENDING_APPROVAL
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum ActionRiskLevel {
  LOW
  MEDIUM
  HIGH
}

model ActionApprovalRequest {
  id                String                  @id @default(cuid())
  actionName        String
  requestedByType   String
  requestedById     String
  status            ApprovalRequestStatus   @default(PENDING)
  risk              ActionRiskLevel         @default(MEDIUM)
  reason            String?
  input             Json
  decidedByUserId   String?
  decidedAt         DateTime?
  expiresAt         DateTime?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  execution         ActionExecution?        @relation("ApprovalExecution")

  @@index([status])
  @@index([actionName])
  @@index([createdAt])
}

enum ApprovalRequestStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
  CANCELLED
}

// ─── Platform Events ─────────────────────────────────────────────────────────

/**
 * Inspectable audit event. Emitted by the object runtime, action dispatcher,
 * workflow engine, agent runner, and approval flow. Powers the activity
 * timeline in Workshop and the `GET /v1/activity` endpoints.
 *
 * `correlationId` groups related events (e.g. all events from a single
 * workflow run or approval decision).
 */
model PlatformEvent {
  id                  String    @id @default(cuid())
  type                String
  actorType           String
  actorId             String
  objectType          String?
  objectId            String?
  actionName          String?
  workflowRunId       String?
  agentRunId          String?
  approvalRequestId   String?
  correlationId       String?
  payload             Json      @default("{}")
  createdAt           DateTime  @default(now())

  @@index([type])
  @@index([objectType, objectId])
  @@index([actorType, actorId])
  @@index([actionName])
  @@index([workflowRunId])
  @@index([agentRunId])
  @@index([correlationId])
  @@index([createdAt])
}

// ─── Inbox ────────────────────────────────────────────────────────────────────

/**
 * A notification surfaced to a specific user. Created by the platform when
 * something requires their attention: a task assignment, an approval request,
 * a workflow failure, an agent handoff, or a message mention.
 */
model InboxItem {
  id                String          @id @default(cuid())
  recipientUserId   String
  type              String          // 'task_assigned' | 'approval_requested' | 'workflow_failed' | 'agent_handoff' | 'mention'
  title             String
  body              String          @default("")
  sourceType        String?         // 'Task' | 'ActionApprovalRequest' | 'WorkflowRun' | 'AgentThread' | 'Message'
  sourceId          String?
  actionUrl         String?
  status            InboxItemStatus @default(UNREAD)
  createdAt         DateTime        @default(now())
  readAt            DateTime?

  @@index([recipientUserId, status])
  @@index([recipientUserId, createdAt])
  @@index([sourceType, sourceId])
}

enum InboxItemStatus {
  UNREAD
  READ
  ARCHIVED
}
