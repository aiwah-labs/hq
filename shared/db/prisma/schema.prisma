generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth ────────────────────────────────────────────────────────────────────

model User {
  id           String            @id @default(cuid())
  email        String            @unique
  /// Null when the user authenticates exclusively via an external identity provider (OIDC/SAML).
  passwordHash String?
  name         String?
  role         UserRole          @default(MEMBER)
  status       UserStatus        @default(ACTIVE)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  /// Soft-delete timestamp. `status = INACTIVE` is used for temporary suspension; deletedAt is irreversible.
  deletedAt    DateTime?
  sessions     Session[]
  identities   IdentityAccount[]
  messages     MsgMessage[]
}

enum UserRole {
  ADMIN
  MEMBER
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

model Session {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// SHA-256 of the session token. Raw tokens are never stored.
  tokenHash  String    @unique
  expiresAt  DateTime
  ipAddress  String?
  userAgent  String?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
}

/// External identity binding. One User may have zero or many IdentityAccounts —
/// one per (provider, providerId) combination. `LOCAL` provider is implied by
/// a non-null `passwordHash` on User; it does not require an IdentityAccount row.
model IdentityAccount {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider    IdentityProvider
  /// IdP instance name (e.g. `google`, `okta`, `azure-ad`, `authentik`).
  providerId  String
  /// Stable external subject (OIDC `sub` claim, SAML NameID).
  subject     String
  email       String?
  rawProfile  Json?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([provider, providerId, subject])
  @@index([userId])
}

enum IdentityProvider {
  LOCAL
  OIDC
  SAML
}

model Bot {
  id          String       @id @default(cuid())
  name        String
  description String?
  scopes      String[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  apiKeys     BotApiKey[]
  messages    MsgMessage[]
}

model BotApiKey {
  id        String    @id @default(cuid())
  botId     String
  bot       Bot       @relation(fields: [botId], references: [id], onDelete: Cascade)
  keyHash   String    @unique
  label     String?
  lastUsed  DateTime?
  createdAt DateTime  @default(now())
}

// ─── Messaging ───────────────────────────────────────────────────────────────

model MsgThread {
  id        String       @id @default(cuid())
  title     String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  messages  MsgMessage[]
}

model MsgMessage {
  id         String    @id @default(cuid())
  threadId   String
  thread     MsgThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  content    String
  senderType String // 'user' | 'bot' | 'agent'
  senderId   String
  userId     String?
  user       User?     @relation(fields: [userId], references: [id])
  botId      String?
  bot        Bot?      @relation(fields: [botId], references: [id])
  createdAt  DateTime  @default(now())
}

// ─── Agents ──────────────────────────────────────────────────────────────────

model AgentRun {
  id         String         @id @default(cuid())
  agentKey   String
  trigger    String
  status     AgentRunStatus @default(RUNNING)
  inputData  Json?
  outputData Json?
  error      String?
  startedAt  DateTime       @default(now())
  finishedAt DateTime?
  steps      AgentRunStep[]
}

enum AgentRunStatus {
  RUNNING
  COMPLETED
  FAILED
}

model AgentRunStep {
  id        String   @id @default(cuid())
  runId     String
  run       AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  type      String // 'llm' | 'tool'
  data      Json
  createdAt DateTime @default(now())
}

// ─── Workflows ───────────────────────────────────────────────────────────────

model WorkflowRun {
  id          String            @id @default(cuid())
  workflowKey String
  status      WorkflowRunStatus @default(PENDING)
  inputData   Json?
  error       String?
  startedAt   DateTime          @default(now())
  finishedAt  DateTime?
  steps       WorkflowRunStep[]
}

enum WorkflowRunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model WorkflowRunStep {
  id         String      @id @default(cuid())
  runId      String
  run        WorkflowRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  nodeId     String
  status     String
  inputData  Json?
  outputData Json?
  error      String?
  startedAt  DateTime    @default(now())
  finishedAt DateTime?
}

// ─── Notes ───────────────────────────────────────────────────────────────────

model Note {
  id        String   @id @default(cuid())
  title     String
  body      String   @default("")
  slug      String?  @unique
  tags      String[]
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Demo Objects ────────────────────────────────────────────────────────────

model Customer {
  id        String         @id @default(cuid())
  name      String
  email     String?        @unique
  phone     String?
  status    CustomerStatus @default(ACTIVE)
  notes     String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
}

model Product {
  id          String        @id @default(cuid())
  name        String
  description String?
  price       Float?
  status      ProductStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

enum ProductStatus {
  ACTIVE
  ARCHIVED
}
