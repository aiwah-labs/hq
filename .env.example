# ─── Branding (customize for your fork) ──────────────────────────────────────
# These control runtime branding. Defaults are generic (`hq`). Override to
# rebrand without touching code.
#   - COOKIE_PREFIX   prefix for session and theme cookie names (default: hq)
#   - API_KEY_PREFIX  prefix for bot API keys (default: hq_, must end with _)
# ⚠ Changing these in production invalidates existing sessions / API keys.
# Also customize the wordmark and logo SVG:
#   - apps/workshop/src/config/brand.ts  (APP_NAME, APP_ICON)
#   - apps/workshop/public/assets/brand/logo-icon.svg
# COOKIE_PREFIX=hq
# API_KEY_PREFIX=hq_

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# Local dev: use the output of `pnpm db:local:bootstrap` (default below).
# Docker: use "postgres" as the host (the compose service name).
DATABASE_URL=postgresql://hq:changeme@localhost:5432/hq_dev
POSTGRES_PASSWORD=changeme

# ─── Session / Auth ───────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-at-least-32-characters-long

# Internal shared secret used by Workshop to authenticate API calls.
# Generate with: openssl rand -hex 32
INTERNAL_API_SECRET=change-me-internal-secret

# Super-admin email allowlist (comma-separated).
# These users are granted the SUPERADMIN role on first login.
SUPERADMIN_EMAIL_ALLOWLIST=admin@example.com

# ─── SSO / OIDC (optional) ────────────────────────────────────────────────────
# Set all three to enable SSO. Leave blank to use local password auth only.
AUTH_OIDC_ISSUER=
AUTH_OIDC_CLIENT_ID=
AUTH_OIDC_CLIENT_SECRET=

# Comma-separated allowed email domains for SSO login.
# Leave blank to allow any domain that passes OIDC.
AUTH_OIDC_ALLOWED_DOMAINS=

# Auto-provision users that pass SSO (default: true)
AUTH_AUTO_PROVISION=true

# Default role for auto-provisioned SSO users (MEMBER | ADMIN)
AUTH_DEFAULT_ROLE=MEMBER

# ─── API ──────────────────────────────────────────────────────────────────────
# Port for the Fastify API (default: 3003)
PORT=3003

# Comma-separated allowed CORS origins.
# Example: https://workshop.example.com,https://app.example.com
API_CORS_ORIGINS=http://localhost:3002

# ─── Workshop ─────────────────────────────────────────────────────────────────
# Base URL of the API that Workshop calls.
NEXT_PUBLIC_API_URL=http://localhost:3003

# ─── MCP ──────────────────────────────────────────────────────────────────────
# API key used to authenticate MCP tool calls from external agents.
# Generate with: openssl rand -hex 32
# Leave blank to disable MCP auth (dev only).
MCP_BOT_API_KEY=

# ─── AI / Model providers ─────────────────────────────────────────────────────
# Add the keys for whichever providers you use.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ─── Storage (optional) ───────────────────────────────────────────────────────
# S3-compatible object storage for file attachments.
# Supported: AWS S3, Cloudflare R2, MinIO.
# Leave blank to disable file attachments.
STORAGE_BUCKET=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_REGION=auto
# Required for R2/MinIO:
STORAGE_ENDPOINT=
# Optional: public base URL if bucket is public
STORAGE_PUBLIC_URL=

# ─── Jobs (pg-boss) ───────────────────────────────────────────────────────────
# pg-boss uses DATABASE_URL by default. No extra vars needed.
# Set this to override the connection string for the job queue.
JOBS_DATABASE_URL=

# ─── Deployment ───────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
